# ============================
# 世界杯数据可视化 — 环境变量
# 复制为 .env 后修改
# ============================

# 服务器端口
API_PORT=3000
WEB_PORT=80

# 日志级别: debug | info | warn | error
LOG_LEVEL=debug

# CORS 允许的域名 (逗号分隔)
# 留空则默认允许 localhost
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 实时比分同步
LIVE_SYNC_INTERVAL=60
LIVE_SYNC_ENABLED=false

# 足球数据 API Key (可选)
# 免费获取: https://www.football-data.org/
FOOTBALL_API_KEY=

# 数据库路径 (可选，默认 backend/worldcup.db)
# DB_PATH=

# CSV 数据路径 (可选)
# CSV_DIR=
# CSV_MATCHES_PATH=
# CSV_COUNTRIES_PATH=
